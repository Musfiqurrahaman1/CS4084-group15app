<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#F8F9FA">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="#FF6B35" android:padding="16dp"
        android:orientation="horizontal" android:gravity="center_vertical">
        <Button android:id="@+id/btnBack" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="← Back"
            android:textColor="#FFFFFF" android:backgroundTint="#E55A24"
            android:layout_marginEnd="12dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Deal Details" android:textColor="#FFFFFF"
            android:textSize="20sp" android:textStyle="bold"/>
    </LinearLayout>

    <ScrollView android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="16dp" app:cardElevation="4dp"
                android:layout_marginBottom="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">

                    <TextView android:id="@+id/tvDetailDiscount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold"
                        android:background="#FF6B35" android:paddingStart="14dp"
                        android:paddingEnd="14dp" android:paddingTop="6dp" android:paddingBottom="6dp"
                        android:layout_marginBottom="14dp"/>

                    <TextView android:id="@+id/tvDetailTitle"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#1A1A2E" android:textSize="22sp" android:textStyle="bold"
                        android:layout_marginBottom="4dp"/>
                    <TextView android:id="@+id/tvDetailStore"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#FF6B35" android:textSize="16sp"
                        android:layout_marginBottom="4dp"/>
                    <TextView android:id="@+id/tvDetailCategory"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#7C4DFF" android:textSize="12sp"
                        android:layout_marginBottom="4dp"/>
                    <TextView android:id="@+id/tvDetailAddress"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#6B7280" android:textSize="12sp"
                        android:layout_marginBottom="14dp"/>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="#F0F0F0" android:layout_marginBottom="14dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="About this deal" android:textColor="#1A1A2E"
                        android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
                    <TextView android:id="@+id/tvDetailDescription"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#6B7280" android:textSize="15sp"
                        android:lineSpacingExtra="4dp" android:layout_marginBottom="16dp"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Rate this deal" android:textColor="#1A1A2E"
                        android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="8dp"/>
                    <RatingBar android:id="@+id/ratingBar"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:numStars="5" android:stepSize="1"
                        android:progressTint="#FF6B35" android:layout_marginBottom="8dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <Button android:id="@+id/btnSaveFavourite" android:layout_width="match_parent"
                android:layout_height="52dp" android:text="Save to Favourites"
                android:textSize="15sp" android:backgroundTint="#FF6B35"
                android:layout_marginBottom="10dp"/>
            <Button android:id="@+id/btnOpenMap" android:layout_width="match_parent"
                android:layout_height="52dp" android:text="📍  Open in Google Maps"
                android:textSize="15sp" android:backgroundTint="#7C4DFF"
                android:layout_marginBottom="10dp"/>
            <Button android:id="@+id/btnVisitWebsite" android:layout_width="match_parent"
                android:layout_height="52dp" android:text="🌐  Visit Website"
                android:textSize="15sp" android:backgroundTint="#00BCD4"
                android:layout_marginBottom="10dp"/>
            <Button android:id="@+id/btnShare" android:layout_width="match_parent"
                android:layout_height="52dp" android:text="📤  Share This Deal"
                android:textSize="15sp" android:backgroundTint="#00C853"
                android:layout_marginBottom="16dp"/>

            <androidx.cardview.widget.CardView xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="16dp" app:cardElevation="4dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="💬 Comments" android:textColor="#1A1A2E"
                        android:textSize="17sp" android:textStyle="bold" android:layout_marginBottom="12dp"/>
                    <LinearLayout android:id="@+id/llComments"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:layout_marginBottom="12dp"/>
                    <EditText android:id="@+id/etComment" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:hint="Write a comment..."
                        android:padding="12dp" android:background="@drawable/rounded_input"
                        android:layout_marginBottom="10dp"/>
                    <Button android:id="@+id/btnAddComment" android:layout_width="match_parent"
                        android:layout_height="48dp" android:text="Post Comment"
                        android:textSize="14sp" android:backgroundTint="#FF6B35"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
