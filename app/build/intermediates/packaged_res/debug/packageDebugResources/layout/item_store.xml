<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_margin="6dp" app:cardCornerRadius="14dp" app:cardElevation="3dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">

        <TextView android:layout_width="48dp" android:layout_height="48dp"
            android:text="📍" android:textSize="28sp" android:gravity="center"
            android:layout_marginEnd="12dp"/>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tvStoreName" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="#1A1A2E"
                android:textSize="15sp" android:textStyle="bold" android:layout_marginBottom="2dp"/>
            <TextView android:id="@+id/tvStoreAddress" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="#6B7280"
                android:textSize="12sp" android:layout_marginBottom="2dp"/>
            <TextView android:id="@+id/tvEircode" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="#9CA3AF"
                android:textSize="11sp" android:layout_marginBottom="6dp"/>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <TextView android:id="@+id/tvStoreDiscount" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#FFFFFF"
                    android:textSize="11sp" android:textStyle="bold" android:background="#FF6B35"
                    android:paddingStart="8dp" android:paddingEnd="8dp"
                    android:paddingTop="2dp" android:paddingBottom="2dp"
                    android:layout_marginEnd="6dp"/>
                <TextView android:id="@+id/tvStoreCategory" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:textColor="#7C4DFF"
                    android:textSize="11sp" android:background="#EDE7F6"
                    android:paddingStart="8dp" android:paddingEnd="8dp"
                    android:paddingTop="2dp" android:paddingBottom="2dp"/>
            </LinearLayout>
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="›" android:textColor="#7C4DFF" android:textSize="24sp"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
