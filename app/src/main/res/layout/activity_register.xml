<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <!-- Logo + Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🎓"
            android:textSize="52sp"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DealMate"
            android:textColor="#1565C0"
            android:textSize="30sp"
            android:textStyle="bold"
            android:layout_gravity="center"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Create your student account"
            android:textColor="#777777"
            android:textSize="14sp"
            android:layout_gravity="center"
            android:layout_marginBottom="28dp"/>

        <!-- Full Name -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Full Name"
            android:textColor="#333333"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>
        <EditText
            android:id="@+id/etFullName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Your full name"
            android:inputType="textPersonName"
            android:padding="14dp"
            android:background="@drawable/rounded_input"
            android:layout_marginBottom="16dp"/>

        <!-- Email -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Student Email"
            android:textColor="#333333"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>
        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="student@college.ie"
            android:inputType="textEmailAddress"
            android:padding="14dp"
            android:background="@drawable/rounded_input"
            android:layout_marginBottom="16dp"/>

        <!-- Password -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textColor="#333333"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>
        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Min. 6 characters"
            android:inputType="textPassword"
            android:padding="14dp"
            android:background="@drawable/rounded_input"
            android:layout_marginBottom="16dp"/>

        <!-- College Spinner -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="College / University"
            android:textColor="#333333"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>
        <Spinner
            android:id="@+id/spinnerCollege"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="14dp"
            android:background="@drawable/rounded_input"
            android:layout_marginBottom="16dp"/>

        <!-- Student ID -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Student ID"
            android:textColor="#333333"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>
        <EditText
            android:id="@+id/etStudentId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="e.g. 23365943 or A1234567"
            android:inputType="textVisiblePassword"
            android:padding="14dp"
            android:background="@drawable/rounded_input"
            android:layout_marginBottom="4dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your unique ID number from your college student card"
            android:textColor="#999999"
            android:textSize="11sp"
            android:layout_marginBottom="16dp"/>

        <!-- Expiry Date -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Student Card Expiry Date"
            android:textColor="#333333"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp"/>
        <EditText
            android:id="@+id/etExpiryDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="MM/YYYY"
            android:inputType="number"
            android:padding="14dp"
            android:background="@drawable/rounded_input"
            android:layout_marginBottom="4dp"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Card must be currently valid. You'll be asked to re-verify each year."
            android:textColor="#999999"
            android:textSize="11sp"
            android:layout_marginBottom="28dp"/>

        <!-- Register Button -->
        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Create Account"
            android:textSize="16sp"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="16dp"/>

        <!-- Login link -->
        <TextView
            android:id="@+id/tvLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Already have an account? Log in"
            android:textColor="#1565C0"
            android:textSize="14sp"
            android:layout_gravity="center"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</ScrollView>
