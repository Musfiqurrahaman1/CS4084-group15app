<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#F8F9FA">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="24dp">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Create Account" android:textColor="#FF6B35" android:textSize="28sp"
            android:textStyle="bold" android:layout_marginTop="24dp" android:layout_marginBottom="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Join DealMate as a verified student" android:textColor="#6B7280"
            android:textSize="14sp" android:layout_marginBottom="28dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Full Name" android:textColor="#1A1A2E" android:textStyle="bold"
            android:textSize="13sp" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/etFullName" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Your full name"
            android:padding="14dp" android:background="@drawable/rounded_input"
            android:layout_marginBottom="16dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Student Email" android:textColor="#1A1A2E" android:textStyle="bold"
            android:textSize="13sp" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/etEmail" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="student@college.ie"
            android:inputType="textEmailAddress" android:padding="14dp"
            android:background="@drawable/rounded_input" android:layout_marginBottom="16dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Password" android:textColor="#1A1A2E" android:textStyle="bold"
            android:textSize="13sp" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/etPassword" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="Min. 6 characters"
            android:inputType="textPassword" android:padding="14dp"
            android:background="@drawable/rounded_input" android:layout_marginBottom="16dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="College / University" android:textColor="#1A1A2E" android:textStyle="bold"
            android:textSize="13sp" android:layout_marginBottom="6dp"/>
        <Spinner android:id="@+id/spinnerCollege" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:padding="14dp"
            android:background="@drawable/rounded_input" android:layout_marginBottom="16dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Student ID" android:textColor="#1A1A2E" android:textStyle="bold"
            android:textSize="13sp" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/etStudentId" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="e.g. 23365943 or A1234567"
            android:inputType="textVisiblePassword" android:padding="14dp"
            android:background="@drawable/rounded_input" android:layout_marginBottom="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Your unique ID from your student card"
            android:textColor="#9CA3AF" android:textSize="11sp" android:layout_marginBottom="16dp"/>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Card Expiry Date" android:textColor="#1A1A2E" android:textStyle="bold"
            android:textSize="13sp" android:layout_marginBottom="6dp"/>
        <EditText android:id="@+id/etExpiryDate" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:hint="MM/YYYY"
            android:inputType="number" android:padding="14dp"
            android:background="@drawable/rounded_input" android:layout_marginBottom="4dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Card must be currently valid. Re-verified each year."
            android:textColor="#9CA3AF" android:textSize="11sp" android:layout_marginBottom="28dp"/>

        <Button android:id="@+id/btnRegister" android:layout_width="match_parent"
            android:layout_height="56dp" android:text="Create Account" android:textSize="17sp"
            android:backgroundTint="#FF6B35" android:layout_marginBottom="16dp"/>
        <TextView android:id="@+id/tvLogin" android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="Already have an account? Log in"
            android:textColor="#7C4DFF" android:textSize="14sp" android:gravity="center"
            android:layout_gravity="center" android:layout_marginBottom="24dp"/>
    </LinearLayout>
</ScrollView>
