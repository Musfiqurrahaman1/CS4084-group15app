<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_margin="6dp" app:cardCornerRadius="16dp" app:cardElevation="4dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">

        <TextView android:id="@+id/tvDiscount" android:layout_width="72dp"
            android:layout_height="72dp" android:gravity="center" android:textColor="#FFFFFF"
            android:textSize="13sp" android:textStyle="bold" android:background="#FF6B35"
            android:layout_marginEnd="14dp"/>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tvDealTitle" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="#1A1A2E"
                android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="4dp"/>
            <TextView android:id="@+id/tvStoreName" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="#6B7280"
                android:textSize="13sp" android:layout_marginBottom="8dp"/>
            <TextView android:id="@+id/tvCategory" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textColor="#7C4DFF"
                android:textSize="11sp" android:background="#EDE7F6"
                android:paddingStart="10dp" android:paddingEnd="10dp"
                android:paddingTop="3dp" android:paddingBottom="3dp"/>
        </LinearLayout>

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="›" android:textColor="#FF6B35" android:textSize="28sp"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>
